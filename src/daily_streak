#!/usr/bin/env python3
"""Generate a GitHub daily streak SVG from historical + recent activity."""

from __future__ import annotations

import argparse
import datetime as dt
import html
import json
import os
import sys
import time
import urllib.error
import urllib.parse
import urllib.request
from dataclasses import dataclass
from typing import Any, Dict, Iterable, List, Mapping, MutableMapping


GITHUB_API = "https://api.github.com"
GITHUB_GRAPHQL = "https://api.github.com/graphql"
MAX_RETRIES = 3
MAX_RETRY_SLEEP_SECONDS = 60
GITHUB_API_VERSION = "2026-03-10"
CACHE_VERSION = 1
HISTORY_REVALIDATE_DAYS = 14


@dataclass
class StreakStats:
    """Summary values displayed in the generated SVG card."""

    total_contributions: int
    current_streak: int
    longest_streak: int
    current_start: dt.date | None
    current_end: dt.date | None
    longest_start: dt.date | None
    longest_end: dt.date | None


def read_json_file(path: str | None) -> dict:
    """Read a JSON object from disk, returning an empty cache on misses."""

    if not path or not os.path.exists(path):
        return {}

    try:
        with open(path, "r", encoding="utf-8") as fh:
            payload = json.load(fh)
    except (OSError, json.JSONDecodeError):
        return {}
    if not isinstance(payload, dict):
        return {}
    return payload


def write_json_file(path: str | None, payload: Mapping[str, Any]) -> None:
    """Atomically write a JSON object to disk."""

    if not path:
        return

    out_path = os.path.abspath(path)
    out_dir = os.path.dirname(out_path)
    if out_dir:
        os.makedirs(out_dir, exist_ok=True)

    tmp_path = f"{out_path}.tmp"
    with open(tmp_path, "w", encoding="utf-8") as fh:
        json.dump(payload, fh, sort_keys=True, separators=(",", ":"))
    os.replace(tmp_path, out_path)


def encode_day_counts(days: Mapping[dt.date, int]) -> dict[str, int]:
    """Serialize date-keyed contribution counts."""

    return {day.isoformat(): count for day, count in sorted(days.items())}


def decode_day_counts(payload: object) -> Dict[dt.date, int]:
    """Deserialize date-keyed contribution counts."""

    if not isinstance(payload, dict):
        return {}

    days: Dict[dt.date, int] = {}
    for key, value in payload.items():
        try:
            days[dt.date.fromisoformat(str(key))] = int(value)
        except (TypeError, ValueError):
            continue
    return days


def load_cache(path: str | None, username: str) -> dict:
    """Load cache only when it belongs to this user and schema version."""

    cache = read_json_file(path)
    if cache.get("version") != CACHE_VERSION or cache.get("username") != username:
        return {"version": CACHE_VERSION, "username": username}
    return cache


def build_headers(token: str | None, etag: str | None = None) -> Dict[str, str]:
    """Build request headers."""

    headers = {
        "Accept": "application/vnd.github+json",
        "X-GitHub-Api-Version": GITHUB_API_VERSION,
        "User-Agent": "DailyStreaks-Bot",
    }
    if token:
        headers["Authorization"] = f"Bearer {token}"
    if etag:
        headers["If-None-Match"] = etag
    return headers


def parse_next_url(link_header: str | None) -> str | None:
    """Extract rel=next from a Link header."""

    if not link_header:
        return None

    for chunk in link_header.split(","):
        part = chunk.strip()
        if 'rel="next"' not in part:
            continue
        start = part.find("<")
        end = part.find(">")
        if start != -1 and end != -1 and end > start:
            return part[start + 1 : end]
    return None


def _header_int(headers: Mapping[str, Any], name: str) -> int | None:
    """Parse an integer response header."""

    value = headers.get(name)
    if value is None:
        return None
    try:
        return int(str(value))
    except ValueError:
        return None


def _is_rate_limit_error(
    status_code: int,
    body: str,
    headers: Mapping[str, Any],
) -> bool:
    """Detect GitHub primary or secondary rate limit responses."""

    body_lower = body.lower()
    return (
        status_code == 429
        or _header_int(headers, "x-ratelimit-remaining") == 0
        or "rate limit" in body_lower
        or "secondary rate" in body_lower
        or "abuse" in body_lower
    )


def _retry_delay_seconds(
    attempt: int,
    headers: Mapping[str, Any],
    rate_limited: bool,
) -> float:
    """Choose a bounded retry delay from GitHub rate-limit headers."""

    retry_after = _header_int(headers, "retry-after")
    if retry_after is not None:
        return min(max(retry_after, 1), MAX_RETRY_SLEEP_SECONDS)

    reset_at = _header_int(headers, "x-ratelimit-reset")
    if _header_int(headers, "x-ratelimit-remaining") == 0 and reset_at is not None:
        reset_delay = reset_at - int(time.time()) + 1
        return min(max(reset_delay, 1), MAX_RETRY_SLEEP_SECONDS)

    if rate_limited:
        return min(60 * (2 ** (attempt - 1)), MAX_RETRY_SLEEP_SECONDS)

    return min(2 ** (attempt - 1), MAX_RETRY_SLEEP_SECONDS)


def _request_json(request: urllib.request.Request, error_prefix: str) -> dict | list:
    """Run HTTP request with retries and parse JSON payload."""

    last_error: Exception | None = None
    for attempt in range(1, MAX_RETRIES + 1):
        try:
            with urllib.request.urlopen(request, timeout=30) as response:
                return json.loads(response.read().decode("utf-8"))
        except urllib.error.HTTPError as exc:
            body = exc.read().decode("utf-8", errors="ignore")
            rate_limited = _is_rate_limit_error(exc.code, body, exc.headers)
            transient = exc.code in {429, 500, 502, 503, 504} or rate_limited
            last_error = RuntimeError(f"{error_prefix} {exc.code}: {body}")
            if transient and attempt < MAX_RETRIES:
                time.sleep(_retry_delay_seconds(attempt, exc.headers, rate_limited))
                continue
            raise last_error from exc
        except urllib.error.URLError as exc:
            last_error = RuntimeError(f"Network error: {exc}")
            if attempt < MAX_RETRIES:
                time.sleep(2 ** (attempt - 1))
                continue
            raise last_error from exc

    raise RuntimeError(str(last_error) if last_error else "Unknown request error")


def _request_json_and_headers(
    request: urllib.request.Request,
    error_prefix: str,
    passthrough_statuses: set[int] | None = None,
) -> tuple[dict | list, Mapping[str, Any]]:
    """Run request with retries and return JSON payload + headers."""

    passthrough_statuses = passthrough_statuses or set()
    last_error: Exception | None = None
    for attempt in range(1, MAX_RETRIES + 1):
        try:
            with urllib.request.urlopen(request, timeout=30) as response:
                payload = json.loads(response.read().decode("utf-8"))
                return payload, response.headers
        except urllib.error.HTTPError as exc:
            if exc.code in passthrough_statuses:
                raise
            body = exc.read().decode("utf-8", errors="ignore")
            rate_limited = _is_rate_limit_error(exc.code, body, exc.headers)
            transient = exc.code in {429, 500, 502, 503, 504} or rate_limited
            last_error = RuntimeError(f"{error_prefix} {exc.code}: {body}")
            if transient and attempt < MAX_RETRIES:
                time.sleep(_retry_delay_seconds(attempt, exc.headers, rate_limited))
                continue
            raise last_error from exc
        except urllib.error.URLError as exc:
            last_error = RuntimeError(f"Network error: {exc}")
            if attempt < MAX_RETRIES:
                time.sleep(2 ** (attempt - 1))
                continue
            raise last_error from exc

    raise RuntimeError(str(last_error) if last_error else "Unknown request error")


def github_get_json(url: str, token: str | None) -> dict | list:
    """GET helper with retries."""

    request = urllib.request.Request(url, headers=build_headers(token))
    return _request_json(request, "GitHub API error")


def github_get_json_cached(
    url: str,
    token: str | None,
    cache: MutableMapping[str, Any] | None,
) -> tuple[dict | list, Mapping[str, Any]]:
    """GET JSON with ETag revalidation when a persistent cache is available."""

    http_cache = cache.setdefault("http", {}) if cache is not None else {}
    cached = http_cache.get(url) if isinstance(http_cache, dict) else None
    etag = cached.get("etag") if isinstance(cached, dict) else None
    request = urllib.request.Request(url, headers=build_headers(token, etag=etag))

    try:
        payload, headers = _request_json_and_headers(
            request,
            "GitHub API error",
            passthrough_statuses={304, 422},
        )
    except urllib.error.HTTPError as exc:
        if exc.code == 304 and isinstance(cached, dict) and "payload" in cached:
            return cached["payload"], {"Link": cached.get("link", "")}
        raise

    if isinstance(http_cache, dict):
        response_etag = headers.get("ETag")
        if response_etag:
            http_cache[url] = {
                "etag": response_etag,
                "link": headers.get("Link", ""),
                "payload": payload,
            }
    return payload, headers


def github_graphql(query: str, variables: dict, token: str | None) -> dict:
    """POST GraphQL helper."""

    body = json.dumps({"query": query, "variables": variables}).encode("utf-8")
    headers = build_headers(token)
    headers["Content-Type"] = "application/json"

    request = urllib.request.Request(
        GITHUB_GRAPHQL,
        data=body,
        headers=headers,
        method="POST",
    )
    raw = _request_json(request, "GitHub GraphQL error")
    payload = raw if isinstance(raw, dict) else {}

    if payload.get("errors"):
        raise RuntimeError(f"GitHub GraphQL returned errors: {payload['errors']}")

    return payload.get("data", {})


def fetch_user_created_date(username: str, token: str | None) -> dt.date:
    """Fetch account creation date."""

    payload = github_get_json(f"{GITHUB_API}/users/{username}", token)
    if not isinstance(payload, dict):
        raise RuntimeError("Unexpected response for user profile")
    created_at = payload.get("created_at")
    if not created_at:
        raise RuntimeError("Unable to read user.created_at from GitHub API")
    return dt.datetime.fromisoformat(created_at.replace("Z", "+00:00")).date()


def fetch_historical_contribution_days(
    username: str,
    token: str | None,
    start_date: dt.date,
    end_date: dt.date,
) -> Dict[dt.date, int]:
    """Fetch day-level contribution counts."""

    query = """
    query($login: String!, $from: DateTime!, $to: DateTime!) {
      user(login: $login) {
        contributionsCollection(from: $from, to: $to) {
          contributionCalendar {
            weeks {
              contributionDays {
                date
                contributionCount
              }
            }
          }
        }
      }
    }
    """

    contributions_by_day: Dict[dt.date, int] = {}
    cursor = start_date

    while cursor <= end_date:
        chunk_end = min(cursor + dt.timedelta(days=364), end_date)
        variables = {
            "login": username,
            "from": f"{cursor.isoformat()}T00:00:00Z",
            "to": f"{chunk_end.isoformat()}T23:59:59Z",
        }
        data = github_graphql(query, variables, token)

        user = data.get("user") or {}
        collection = user.get("contributionsCollection") or {}
        calendar = collection.get("contributionCalendar") or {}
        weeks = calendar.get("weeks") or []

        for week in weeks:
            for day in week.get("contributionDays", []):
                day_date = dt.date.fromisoformat(day["date"])
                count = int(day.get("contributionCount", 0))
                contributions_by_day[day_date] = contributions_by_day.get(day_date, 0) + count

        cursor = chunk_end + dt.timedelta(days=1)

    return contributions_by_day


def fetch_contribution_days_with_cache(
    username: str,
    token: str | None,
    today: dt.date,
    cache: MutableMapping[str, Any],
) -> Dict[dt.date, int]:
    """Fetch contribution days incrementally instead of refetching full history."""

    cached_days = decode_day_counts(cache.get("historical_days"))
    if cached_days:
        latest_cached_day = max(cached_days)
        revalidate_from = min(latest_cached_day, today) - dt.timedelta(
            days=HISTORY_REVALIDATE_DAYS,
        )
        start_date = max(revalidate_from, min(cached_days))
    else:
        start_date = fetch_user_created_date(username, token)

    refreshed_days = fetch_historical_contribution_days(username, token, start_date, today)
    for day in list(cached_days):
        if day >= start_date:
            cached_days.pop(day)
    cached_days.update(refreshed_days)

    cache["historical_days"] = encode_day_counts(cached_days)
    cache["updated_at"] = dt.datetime.now(dt.timezone.utc).isoformat(timespec="seconds")
    return cached_days


def fetch_recent_push_events(
    username: str,
    token: str | None,
    max_pages: int = 5,
    lookback_days: int = 45,
    cache: MutableMapping[str, Any] | None = None,
) -> List[dict]:
    """Fetch recent public events."""

    max_pages = max(1, min(max_pages, 10))
    lookback_days = max(1, lookback_days)

    cutoff = dt.datetime.now(dt.timezone.utc) - dt.timedelta(days=lookback_days)
    params = urllib.parse.urlencode({"per_page": 100})
    next_url: str | None = f"{GITHUB_API}/users/{username}/events/public?{params}"

    events: List[dict] = []
    page_count = 0

    while next_url and page_count < max_pages:
        try:
            payload, headers = github_get_json_cached(next_url, token, cache)
            link_header = headers.get("Link")
        except urllib.error.HTTPError as exc:
            msg = exc.read().decode("utf-8", errors="ignore")
            if exc.code == 422 and "pagination is limited" in msg.lower():
                break
            raise RuntimeError(f"GitHub API error {exc.code}: {msg}") from exc

        page_count += 1
        if not payload:
            break
        if not isinstance(payload, list):
            raise RuntimeError("Unexpected response for public events")

        events.extend(payload)
        next_url = parse_next_url(link_header)

        oldest = None
        for event in payload:
            created_at = event.get("created_at")
            if not created_at:
                continue
            ts = dt.datetime.fromisoformat(created_at.replace("Z", "+00:00"))
            oldest = ts if oldest is None else min(oldest, ts)
        if oldest and oldest < cutoff:
            break

    return events


def aggregate_push_commits_by_day(events: Iterable[dict], timezone: dt.timezone) -> Dict[dt.date, int]:
    """Aggregate PushEvent commits by local day."""

    push_counts: Dict[dt.date, int] = {}

    for event in events:
        if event.get("type") != "PushEvent":
            continue

        commit_count = len(event.get("payload", {}).get("commits", []))
        if commit_count <= 0:
            continue

        created_at = event.get("created_at")
        if not created_at:
            continue

        timestamp = dt.datetime.fromisoformat(created_at.replace("Z", "+00:00"))
        local_day = timestamp.astimezone(timezone).date()
        push_counts[local_day] = push_counts.get(local_day, 0) + commit_count

    return push_counts


def escape_svg_text(value: object) -> str:
    """Escape text before rendering SVG nodes."""

    return html.escape(str(value), quote=False)


def merge_historical_with_recent(
    historical_days: Dict[dt.date, int],
    recent_push_days: Dict[dt.date, int],
) -> Dict[dt.date, int]:
    """Merge historical counts with recent pushes."""

    merged = dict(historical_days)

    for day, push_count in recent_push_days.items():
        merged[day] = max(merged.get(day, 0), push_count)

    return merged


def compute_streaks(contributions_by_day: Dict[dt.date, int], today: dt.date) -> StreakStats:
    """Compute current and longest streak."""

    active_days = sorted(day for day, count in contributions_by_day.items() if count > 0)
    if not active_days:
        return StreakStats(0, 0, 0, None, None, None, None)

    total_contributions = sum(count for count in contributions_by_day.values() if count > 0)

    longest_len = 1
    longest_start = active_days[0]
    longest_end = active_days[0]

    run_start = active_days[0]
    prev = active_days[0]

    for day in active_days[1:]:
        if (day - prev).days == 1:
            prev = day
            continue

        run_len = (prev - run_start).days + 1
        if run_len > longest_len:
            longest_len = run_len
            longest_start = run_start
            longest_end = prev

        run_start = day
        prev = day

    run_len = (prev - run_start).days + 1
    if run_len > longest_len:
        longest_len = run_len
        longest_start = run_start
        longest_end = prev

    latest = active_days[-1]

    if (today - latest).days > 1:
        current_len = 0
        current_start = None
        current_end = None
    else:
        current_end = latest
        current_start = latest
        active_set = set(active_days)

        while current_start - dt.timedelta(days=1) in active_set:
            current_start -= dt.timedelta(days=1)
        current_len = (current_end - current_start).days + 1

    return StreakStats(
        total_contributions=total_contributions,
        current_streak=current_len,
        longest_streak=longest_len,
        current_start=current_start,
        current_end=current_end,
        longest_start=longest_start,
        longest_end=longest_end,
    )


def day_fmt(day: dt.date) -> str:
    """Cross-platform long date format."""

    return day.strftime("%b %-d, %Y") if os.name != "nt" else day.strftime("%b %d, %Y")


def short_day_fmt(day: dt.date) -> str:
    """Cross-platform short date format."""

    return day.strftime("%b %-d") if os.name != "nt" else day.strftime("%b %d")


def format_range(start: dt.date | None, end: dt.date | None) -> str:
    """Render a compact date range."""

    if not start or not end:
        return "No active streak"
    if start == end:
        return day_fmt(start)
    if start.year == end.year:
        return f"{short_day_fmt(start)} - {day_fmt(end)}"
    return f"{day_fmt(start)} - {day_fmt(end)}"


def render_svg(username: str, stats: StreakStats) -> str:
    """Build the SVG card."""

    safe_username = escape_svg_text(username)
    safe_total = escape_svg_text(stats.total_contributions)
    safe_current_streak = escape_svg_text(stats.current_streak)
    safe_current_range = escape_svg_text(format_range(stats.current_start, stats.current_end))
    safe_longest_streak = escape_svg_text(stats.longest_streak)
    safe_longest_range = escape_svg_text(format_range(stats.longest_start, stats.longest_end))

    return f"""<svg width=\"900\" height=\"220\" viewBox=\"0 0 900 220\" preserveAspectRatio=\"xMidYMid meet\" style=\"max-width:900px;width:100%;height:auto;\" xmlns=\"http://www.w3.org/2000/svg\" role=\"img\" aria-label=\"GitHub streak stats\">
  <defs>
    <linearGradient id=\"bg\" x1=\"0\" x2=\"1\" y1=\"0\" y2=\"1\">
      <stop offset=\"0%\" stop-color=\"#0d1117\"/>
      <stop offset=\"100%\" stop-color=\"#161b22\"/>
    </linearGradient>
  </defs>
  <rect width=\"900\" height=\"220\" rx=\"18\" fill=\"url(#bg)\"/>
  <text x=\"450\" y=\"32\" text-anchor=\"middle\" font-family=\"Segoe UI, Ubuntu, sans-serif\" font-size=\"20\" fill=\"#58a6ff\">{safe_username} • DailyStreaks</text>

  <line x1=\"300\" y1=\"55\" x2=\"300\" y2=\"195\" stroke=\"#30363d\"/>
  <line x1=\"600\" y1=\"55\" x2=\"600\" y2=\"195\" stroke=\"#30363d\"/>

  <text x=\"150\" y=\"98\" text-anchor=\"middle\" font-family=\"Segoe UI, Ubuntu, sans-serif\" font-weight=\"700\" font-size=\"52\" fill=\"#c9d1d9\">{safe_total}</text>
  <text x=\"150\" y=\"135\" text-anchor=\"middle\" font-family=\"Segoe UI, Ubuntu, sans-serif\" font-size=\"28\" fill=\"#8b949e\">Total Daily Contributions</text>

  <text x=\"450\" y=\"88\" text-anchor=\"middle\" font-family=\"Segoe UI Emoji, Segoe UI Symbol\" font-size=\"34\" fill=\"#ffa657\">🔥</text>
  <text x=\"450\" y=\"118\" text-anchor=\"middle\" font-family=\"Segoe UI, Ubuntu, sans-serif\" font-weight=\"700\" font-size=\"54\" fill=\"#ffa657\">{safe_current_streak}</text>
  <text x=\"450\" y=\"154\" text-anchor=\"middle\" font-family=\"Segoe UI, Ubuntu, sans-serif\" font-size=\"30\" fill=\"#ffa657\">Current Streak (days)</text>
  <text x=\"450\" y=\"184\" text-anchor=\"middle\" font-family=\"Segoe UI, Ubuntu, sans-serif\" font-size=\"21\" fill=\"#8b949e\">{safe_current_range}</text>

  <text x=\"750\" y=\"98\" text-anchor=\"middle\" font-family=\"Segoe UI, Ubuntu, sans-serif\" font-weight=\"700\" font-size=\"52\" fill=\"#c9d1d9\">{safe_longest_streak}</text>
  <text x=\"750\" y=\"135\" text-anchor=\"middle\" font-family=\"Segoe UI, Ubuntu, sans-serif\" font-size=\"28\" fill=\"#8b949e\">Longest Streak (days)</text>
  <text x=\"750\" y=\"170\" text-anchor=\"middle\" font-family=\"Segoe UI, Ubuntu, sans-serif\" font-size=\"21\" fill=\"#8b949e\">{safe_longest_range}</text>
</svg>
"""


def parse_timezone(offset_hours: int) -> dt.timezone:
    """Create timezone from integer UTC offset."""

    if offset_hours < -12 or offset_hours > 14:
        raise ValueError("timezone offset must be between -12 and +14")

    return dt.timezone(dt.timedelta(hours=offset_hours))


def main() -> int:
    """CLI entrypoint."""

    parser = argparse.ArgumentParser(description="Generate GitHub daily streak SVG")
    parser.add_argument("--username", required=True, help="GitHub username")
    parser.add_argument("--token", default=os.getenv("GITHUB_TOKEN"), help="GitHub API token")
    parser.add_argument("--timezone-offset", type=int, default=0, help="UTC offset in hours")
    parser.add_argument("--max-pages", type=int, default=5, help="Max event pages for recent pushes (1-10)")
    parser.add_argument("--lookback-days", type=int, default=45, help="Recent event lookback window")
    parser.add_argument("--output", default="assets/github-streak.svg", help="Output SVG path")
    parser.add_argument("--events-file", help="Optional local JSON events file (offline testing mode)")
    parser.add_argument("--cache-file", help="Optional persistent API cache file")
    args = parser.parse_args()

    try:
        timezone = parse_timezone(args.timezone_offset)
    except ValueError as exc:
        parser.error(str(exc))
    today = dt.datetime.now(timezone).date()

    cache = load_cache(args.cache_file, args.username)

    try:
        if args.events_file:
            with open(args.events_file, "r", encoding="utf-8") as fh:
                events = json.load(fh)
            historical_days: Dict[dt.date, int] = {}
            recent_push_days = aggregate_push_commits_by_day(events, timezone)
            merged_days = merge_historical_with_recent(historical_days, recent_push_days)
        else:
            historical_days = fetch_contribution_days_with_cache(
                username=args.username,
                token=args.token,
                today=today,
                cache=cache,
            )

            recent_events = fetch_recent_push_events(
                username=args.username,
                token=args.token,
                max_pages=args.max_pages,
                lookback_days=args.lookback_days,
                cache=cache,
            )
            recent_push_days = aggregate_push_commits_by_day(recent_events, timezone)
            merged_days = merge_historical_with_recent(historical_days, recent_push_days)
            write_json_file(args.cache_file, cache)
    except (OSError, ValueError, RuntimeError, json.JSONDecodeError) as exc:
        print(f"Error: {exc}", file=sys.stderr)
        return 2

    stats = compute_streaks(merged_days, today)

    svg = render_svg(args.username, stats)
    out_path = os.path.abspath(args.output)
    out_dir = os.path.dirname(out_path)
    if out_dir:
        os.makedirs(out_dir, exist_ok=True)
    with open(out_path, "w", encoding="utf-8") as fh:
        fh.write(svg)

    print(
        json.dumps(
            {
                "username": args.username,
                "total_contributions": stats.total_contributions,
                "current_streak": stats.current_streak,
                "longest_streak": stats.longest_streak,
                "days_with_contributions": sum(1 for v in merged_days.values() if v > 0),
                "output": args.output,
            },
